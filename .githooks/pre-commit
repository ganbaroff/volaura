#!/bin/bash
# Pre-commit hook: detect secrets before they enter the repo
# Inspired by ruflo's .githooks/pre-commit pattern

echo "🔒 Checking for secrets..."

# Patterns that should never be in committed code
PATTERNS=(
    'sk-[a-zA-Z0-9]{20,}'           # OpenAI API keys
    'AIza[a-zA-Z0-9_-]{35}'          # Google API keys
    'sbp_[a-zA-Z0-9]{40,}'           # Supabase service keys
    'eyJhbGciOi[a-zA-Z0-9_=-]{50,}'  # JWT tokens (long ones)
    'PRIVATE KEY'                      # Private keys
    'password\s*=\s*["\x27][^"\x27]{8,}' # Hardcoded passwords
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|py|js|jsx|json|env|yml|yaml|toml)$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND=0
for pattern in "${PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | xargs grep -lnE "$pattern" 2>/dev/null)
    if [ -n "$MATCHES" ]; then
        echo "❌ Possible secret found matching pattern: $pattern"
        echo "$MATCHES"
        FOUND=1
    fi
done

if [ $FOUND -eq 1 ]; then
    echo ""
    echo "⛔ Commit blocked: possible secrets detected."
    echo "   Remove secrets and use environment variables instead."
    echo "   To bypass (NOT recommended): git commit --no-verify"
    exit 1
fi

echo "✅ No secrets detected."
exit 0
