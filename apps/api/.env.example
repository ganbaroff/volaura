# Volaura API — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# OR run: pnpm setup:env (pulls from Railway automatically)

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://hvykysvdkalkbswmgfut.supabase.co
SUPABASE_SERVICE_KEY=       # sb_secret_... (from Supabase dashboard → Settings → API)
SUPABASE_ANON_KEY=          # sb_publishable_... (from Supabase dashboard → Settings → API)

# ── App ───────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_PORT=8000

# ── LLM — Primary ────────────────────────────────────────
GEMINI_API_KEY=             # AIzaSy... (from Google AI Studio)
OPENAI_API_KEY=             # sk-proj-... (optional, fallback only)

# ── LLM — Swarm providers (free tier) ────────────────────
GROQ_API_KEY=               # gsk_... (from console.groq.com)
DEEPSEEK_API_KEY=           # sk-... (from platform.deepseek.com)

# ── LLM — Azure OpenAI (swarm) ───────────────────────────
# Bump version when adding newer models (e.g. o4-mini needs >=2024-12-01-preview).
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Telegram (@volaurabot) ────────────────────────────────
TELEGRAM_BOT_TOKEN=         # from @BotFather
TELEGRAM_CEO_CHAT_ID=       # Yusif's Telegram numeric ID
TELEGRAM_WEBHOOK_SECRET=volaura-swarm-2026

# ── Observability — Langfuse LLM tracing ─────────────────
# Free tier: 50k events/month. Leave empty to disable tracing.
LANGFUSE_PUBLIC_KEY=          # pk-lf-... (from cloud.langfuse.com → Settings → API Keys)
LANGFUSE_SECRET_KEY=          # sk-lf-... (from cloud.langfuse.com → Settings → API Keys)
LANGFUSE_HOST=https://cloud.langfuse.com  # EU default; US = https://us.cloud.langfuse.com

# ── Stripe (MVP-1, not yet active) ───────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Org billing (B2B screening pivot) — report paywall ───
# ORG_BILLING_ENABLED=false: campaign report stays free (design-partner phase).
# Flip to true on Railway to gate GET /api/campaigns/{id}/report behind payment.
ORG_BILLING_ENABLED=false
# Separate Stripe webhook endpoint secret for /api/org-billing/webhook (isolated from B2C).
STRIPE_ORG_WEBHOOK_SECRET=
# Recurring org 'package' subscription price (refounding brief: 250-500 AZN/month).
STRIPE_ORG_SUBSCRIPTION_PRICE_ID=
# One-time single-campaign report unlock price.
STRIPE_CAMPAIGN_REPORT_PRICE_ID=

# ── Firebase — MindShift mobile push notifications (FCM) ─
# Base64-encoded Firebase Admin SDK service account JSON
# From: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Project: mindshift-441e8
# Encode: base64 -w0 firebase-adminsdk.json
FIREBASE_MINDSHIFT_CREDENTIALS_B64=
