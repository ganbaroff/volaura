{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebSearch",
      "WebFetch(*)",
      "mcp__*",
      "mcp__claude_ai_Supabase__list_projects",
      "mcp__claude_ai_Supabase__list_migrations",
      "mcp__claude_ai_Supabase__execute_sql",
      "mcp__supabase__list_migrations",
      "mcp__claude_ai_Figma__get_variable_defs",
      "mcp__claude_ai_Figma__get_metadata",
      "mcp__claude_ai_Sentry__search_issues",
      "mcp__claude_ai_Vercel__list_deployments",
      "mcp__claude_ai_Vercel__list_teams",
      "mcp__claude_ai_Vercel__list_projects",
      "Bash(ls -la .git/*.lock .git/index.lock)",
      "Bash(rm -f .git/index.lock .git/HEAD.lock .git/refs/heads/main.lock)",
      "Bash(ls .git/*.lock)",
      "mcp__claude_ai_Supabase__apply_migration"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf /*)",
      "Bash(rm -r /c*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)",
      "Bash(: > *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/style-brake.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-protocol.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/trailing-question-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/voice-breach-check.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact-checkpoint.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact-restore.sh"
          }
        ]
      }
    ]
  }
}
