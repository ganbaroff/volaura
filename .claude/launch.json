{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/next/dist/bin/next", "dev", "apps/web", "--port", "3000"],
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "apps/api/.venv/Scripts/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000", "--app-dir", "apps/api"],
      "port": 8000
    }
  ]
}
