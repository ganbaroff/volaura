{
  "name": "@volaura/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "prebuild": "rm -rf .next/server/app/\\[locale\\]/\\(admin\\)/page_client-reference-manifest.js 2>/dev/null || true",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-ts -c @hey-api/client-fetch -i http://localhost:8000/openapi.json -o src/lib/api/generated -p @hey-api/typescript @hey-api/sdk",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.67.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.0.0",
    "i18next": "^24.2.0",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.474.0",
    "next": "14.2.35",
    "next-i18n-router": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.4.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.0",
    "@hey-api/openapi-ts": "^0.67.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
